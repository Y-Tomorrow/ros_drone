#!/usr/bin/env python3
# -*- coding: utf-8 -*-
"""
rosrun wrapper for target_searcher_tester (C++ binary).

原因：rosrun 默认在包目录下找可执行文件，而 catkin_make 的 C++ 可执行文件在工作区 devel/lib/<pkg>/ 下。
因此提供一个位于 scripts/ 的薄包装脚本，让 rosrun 能直接运行该测试程序。
"""

import os
import sys


def _find_ws_root_from_pkg_path(pkg_path: str) -> str:
    # /.../ros_drone/src/ros_drone -> ws_root=/.../ros_drone
    return os.path.dirname(os.path.dirname(pkg_path))


def main():
    try:
        import rospkg

        pkg_path = rospkg.RosPack().get_path("ros_drone")
    except Exception as e:
        sys.stderr.write(f"[target_searcher_tester wrapper] rospkg error: {e}\n")
        return 2

    ws_root = _find_ws_root_from_pkg_path(pkg_path)
    exe = os.path.join(ws_root, "devel", "lib", "ros_drone", "target_searcher_tester_bin")

    if not os.path.isfile(exe):
        sys.stderr.write(
            "[target_searcher_tester wrapper] binary not found:\n"
            f"  {exe}\n"
            "你需要先在工作区执行: catkin_make\n"
        )
        return 3
    if not os.access(exe, os.X_OK):
        sys.stderr.write(
            "[target_searcher_tester wrapper] binary exists but not executable:\n"
            f"  {exe}\n"
        )
        return 4

    os.execv(exe, [exe] + sys.argv[1:])


if __name__ == "__main__":
    raise SystemExit(main())

